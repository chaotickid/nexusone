{
  "name": "nexusone",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "daisyui": "^4.7.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "papaparse": "^5.5.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.app.NexusOne",
    "productName": "NexusOne",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "requestedExecutionLevel": "highestAvailable"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      "users.json"
    ]
  }
}